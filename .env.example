# ═════════════════════════════════════════════════════════════════════
# HerWell — Environment Variables
# ═════════════════════════════════════════════════════════════════════
# Copy this file to `.env` and fill in your values.
# For local development, only Database and Backend sections are needed.
# For production deployment, all sections must be configured.
# ═════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────
# DATABASE
# ───────────────────────────────────────────────
# Used by both the backend (Express) and the db service in docker-compose
DB_HOST=db
DB_PORT=5432
DB_USER=herwell
DB_PASSWORD=changeme_use_a_strong_password
DB_NAME=herwell_db

# ───────────────────────────────────────────────
# BACKEND
# ───────────────────────────────────────────────
# The backend listens on PORT inside the container.
# In docker-compose.prod.yml, no host port is mapped; the container is
# reached by other containers on the internal network.
NODE_ENV=production
PORT=3001
# Generate a strong 64-character hex string:  openssl rand -hex 64
JWT_SECRET=replace_with_64_char_random_string
JWT_EXPIRES_IN=7d
# Set this to the public URL of your deployed app (e.g. http://YOUR_EC2_PUBLIC_IP)
CORS_ORIGIN=http://YOUR_EC2_PUBLIC_IP

# PostgreSQL connection — these match the DB_* vars above, renamed as
# POSTGRES_* for the postgres Docker image.
POSTGRES_USER=herwell
POSTGRES_PASSWORD=changeme_use_a_strong_password
POSTGRES_DB=herwell_db
# The backend uses DB_HOST/DB_USER/etc. but the docker-compose db service
# reads POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB from the same .env file.
# Both sets are included here for clarity.

# ───────────────────────────────────────────────
# FRONTEND BUILD-TIME (Vite)
# ───────────────────────────────────────────────
# Must be prefixed with VITE_ to be exposed to the browser at build time.
# This is passed as a Docker build-arg when building the frontend image.
VITE_API_URL=http://YOUR_EC2_PUBLIC_IP/api

# ───────────────────────────────────────────────
# GRAFANA
# ───────────────────────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=changeme_grafana_admin_password
GF_USERS_ALLOW_SIGN_UP=false
