# ── HerWell Environment Variables ─────────────────────────────────
# Copy to .env and fill in your values.
# Generate secure passwords: openssl rand -hex 32
# Generate JWT secret:       openssl rand -hex 64

# Database
DB_HOST=db
DB_PORT=5432
DB_USER=herwell
DB_PASSWORD=changeme_use_a_strong_password
DB_NAME=herwell_db

# Backend (Express)
NODE_ENV=production
PORT=3001
JWT_SECRET=replace_with_64_char_random_string
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://YOUR_EC2_PUBLIC_IP

# PostgreSQL (for the db service)
POSTGRES_USER=herwell
POSTGRES_PASSWORD=changeme_use_a_strong_password
POSTGRES_DB=herwell_db

# Frontend (Vite build-time arg)
VITE_API_URL=http://YOUR_EC2_PUBLIC_IP/api

# Grafana
GF_SECURITY_ADMIN_PASSWORD=changeme_grafana_admin_password
GF_USERS_ALLOW_SIGN_UP=false
